# VirtualFusion Stock Analyzer - Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ===========================================
# NGROK TUNNEL SECURITY (required when using ngrok)
# ===========================================
# Basic Auth protects your tunnel from unauthorized access.
# Password must be 8-128 characters.
NGROK_AUTH_USER=your_username
NGROK_AUTH_PASS=your_secure_password_min_8_chars

# ===========================================
# API KEYS (optional - Yahoo Finance works without)
# ===========================================
# Alpha Vantage for additional data (get free key at alphavantage.co)
ALPHA_VANTAGE_API_KEY=
