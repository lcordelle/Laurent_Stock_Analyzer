# VirtualFusion Stock Analyzer — copy to .env:  cp .env.example .env

# ===========================================
# APP LOGIN (used by utils/auth.py)
# ===========================================
# Set to true to skip login entirely (trusted networks / dev only).
# APP_AUTH_DISABLED=false

# If unset, defaults are laurent / changeme (change for production).
APP_AUTH_USER=laurent
APP_AUTH_PASS=your_secure_password_min_8_chars

# Legacy aliases (still supported if APP_AUTH_* not set)
# NGROK_AUTH_USER=
# NGROK_AUTH_PASS=

# ===========================================
# API KEYS (optional - Yahoo Finance works without)
# ===========================================
ALPHA_VANTAGE_API_KEY=

# ===========================================
# AI ANALYST REPORT — pick one free option
# ===========================================

# OPTION 1: Groq (recommended — free tier, Llama 3.3 70B, ~1s)
# Sign up free at console.groq.com — no credit card
GROQ_API_KEY=

# OPTION 2: Ollama (local, fully offline, no account needed)
# brew install ollama && ollama pull llama3.2 && ollama serve
# No key required — app auto-detects Ollama at localhost:11434

# OPTION 3: Anthropic Claude (paid, highest quality)
# Get key at console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides
# AI_ANALYST_PROVIDER=groq         # force a specific provider
# AI_ANALYST_MODEL=llama-3.1-8b-instant  # override the default model
